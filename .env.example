# --- Database Configuration # Local Databse URL ---
DATABASE_URL=postgresql://postgres:postgres@db:5432/prepai

# --- Vector Database ---
QDRANT_URL=http://qdrant:6333

# --- Code Execution Sandbox ---
PISTON_URL=http://piston:2000

# --- Authentication Settings ---
# Generate a secure secret key for production (e.g. openssl rand -hex 32)
JWT_SECRET=prepai_super_secret_key_12345_67890
JWT_EXPIRE_MINUTES=1440

# --- Gemini API Configuration ---
# REQUIRED: Retrieve a Gemini API Key from Google AI Studio
GOOGLE_API_KEY=your_google_api_key_here

# --- LlamaParse API Configuration (Optional) ---
# OPTIONAL: Retrieve a LlamaCloud API Key from cloud.llamaindex.ai for scanned PDF OCR support
LLAMA_CLOUD_API_KEY=

# --- LangSmith Tracing (Optional) ---
LANGCHAIN_TRACING_V2=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=prep-ai

# --- Frontend API Exposure ---
# The URL where the frontend browser code will reach the backend API
VITE_API_BASE_URL=http://localhost:8000/api
